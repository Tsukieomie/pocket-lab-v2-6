# Runtime tunnel state — bore external ports rotate every session.
bore-port.txt
pocket-current-ssh

# iSH write bridge — runtime symlink and any device-specific bridge state
# that may end up in the working tree. The bridge itself lives inside the
# iSH app-group container (UUID is device-specific) and must never be
# committed.
ios-write
**/PocketLabWriteBridge/
.write-test-*

# Logs
*.log

# SSH / Dropbear secrets — never commit private device material.
# (linux/security/authorized_keys is already tracked and contains only a
# public computer-session key; gitignore does not retroactively untrack.)
**/authorized_keys
**/dropbear_*_hostkey
**/dropbear_*_hostkey.pub
**/ssh_host_*_key
**/ssh_host_*_key.pub
*.pem
id_rsa
id_ed25519
.bore_env

# BIOS binaries (large, machine-specific — distribute via smt_fetch_bios.sh)
X513IAAS.308
X513IAAS.308.smt_patched
*.smt_patched
bios_backup_*.bin
bios_backup_*.bin.sha256
